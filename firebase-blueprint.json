{
  "entities": {
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "An architectural project showcased in the portfolio grid.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "img": { "type": "string" },
        "deliveryUrl": { "type": "string" },
        "description": { "type": "string" },
        "gallery": { "type": "array" },
        "bannerText": { "type": "string" },
        "bannerColor": { "type": "string" },
        "bannerSize": { "type": "string" },
        "order": { "type": "number" },
        "hidden": { "type": "boolean" },
        "url": { "type": "string" },
        "externalLink": { "type": "string" },
        "mlsNumber": { "type": "string" },
        "listPrice": { "type": "string" },
        "propertyType": { "type": "string" },
        "beds": { "type": "string" },
        "baths": { "type": "string" },
        "sqft": { "type": "string" },
        "status": { "type": "string" },
        "daysOnMarket": { "type": "number" },
        "colSpan": { "type": "number" },
        "rowSpan": { "type": "number" },
        "type": { "type": "string" },
        "panel": { "type": "string" },
        "partnerUid": { "type": "string" },
        "partnerUids": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "img", "order", "createdAt", "updatedAt"]
    },
    "Service": {
      "title": "Service Tier",
      "description": "A service offering provided by The Exposed Brick.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "url": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "order", "createdAt", "updatedAt"]
    },
    "Inquiry": {
      "title": "Project Inquiry",
      "description": "A message from a potential client.",
      "type": "object",
      "properties": {
        "propertyAddress": { "type": "string" },
        "realtorName": { "type": "string" },
        "serviceType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyAddress", "realtorName", "serviceType", "createdAt"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration and branding for the application.",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "logoText": { "type": "string" },
        "logoLight": { "type": "string" },
        "logoDark": { "type": "string" },
        "tagline": { "type": "string" },
        "heroTitlePart1": { "type": "string" },
        "heroTitlePart2": { "type": "string" },
        "heroTitleAccent": { "type": "string" },
        "heroImage": { "type": "string" },
        "heroAlignment": { "type": "string", "enum": ["left", "center"] },
        "accentColor": { "type": "string" },
        "footerQuote": { "type": "string" },
        "inquiryTitle": { "type": "string" },
        "servicesTitle": { "type": "string" },
        "servicesSubtitle": { "type": "string" },
        "homeSectionsOrder": { "type": "array", "items": { "type": "string" } },
        "navigationItems": { "type": "array", "items": { "type": "object" } },
        "socialLinks": { "type": "array", "items": { "type": "object" } },
        "contactInfo": { "type": "object" },
        "fontTitle": { "type": "string" },
        "fontBody": { "type": "string" },
        "layout": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CustomPage": {
      "title": "Custom Page",
      "description": "A dynamically created page on the website.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "showInNav": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User Profile",
      "description": "User profile containing brand assets and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "headshotUrl": { "type": "string" },
        "logoUrl": { "type": "string" },
        "instagram": { "type": "string" },
        "facebook": { "type": "string" },
        "linkedin": { "type": "string" },
        "bio": { "type": "string" },
        "teamId": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "partner", "admin", "preferred"] },
        "resources": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Team": {
      "title": "Team",
      "description": "A group of agents associated with a single brand/group.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "leaderUid": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "brandGuideUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "A lead submitted by a client/partner",
      "type": "object",
      "properties": {
        "referrerUid": { "type": "string" },
        "referralName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Contacting...", "Pending", "Booked", "Completed"] },
        "rewardEarned": { "type": "string" },
        "value": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerUid", "referralName", "status", "createdAt"]
    },
    "AdminUser": {
      "title": "Admin User",
      "description": "A user with administrative privileges.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin"] },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "addedAt"]
    }
  },
  "firestore": {
    "portfolio_items": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio projects."
    },
    "services": {
      "schema": "Service",
      "description": "Collection of service offerings."
    },
    "inquiries": {
      "schema": "Inquiry",
      "description": "Collection of project inquiries."
    },
    "settings": {
      "schema": "SiteSettings",
      "description": "Global site configuration (usually one document 'main')."
    },
    "pages": {
      "schema": "CustomPage",
      "description": "User-generated custom pages."
    },
    "admins": {
      "schema": "AdminUser",
      "description": "Authorized administrators."
    },
    "users": {
      "schema": "User",
      "description": "User profiles including brand assets."
    },
    "teams": {
      "schema": "Team",
      "description": "Teams grouping multiple partners."
    },
    "referrals": {
      "schema": "Referral",
      "description": "Referrals submitted by users."
    }
  }
}
