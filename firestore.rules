rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jasonmurdy@gmail.com' || 
        request.auth.token.email == 'sherwin.131986@gmail.com' ||
        (request.auth.token.get('email_verified', false) == true && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidPortfolioItem(data) {
      return data.title is string && data.title.size() <= 500
        && data.category is string && data.category.size() <= 200
        && data.img is string && data.img.size() <= 5000
        && (data.get('url', null) == null || (data.url is string && data.url.size() <= 5000))
        && (data.get('description', null) == null || (data.description is string && data.description.size() <= 10000))
        && (data.get('gallery', null) == null || (data.gallery is list))
        && (data.get('mlsNumber', null) == null || (data.mlsNumber is string && data.mlsNumber.size() <= 200))
        && (data.get('listPrice', null) == null || (data.listPrice is string && data.listPrice.size() <= 100))
        && (data.get('propertyType', null) == null || (data.propertyType is string && data.propertyType.size() <= 300))
        && (data.get('beds', null) == null || (data.beds is string && data.beds.size() <= 50))
        && (data.get('baths', null) == null || (data.baths is string && data.baths.size() <= 50))
        && (data.get('sqft', null) == null || (data.sqft is string && data.sqft.size() <= 50))
        && (data.get('status', null) == null || (data.status is string && data.status.size() <= 100))
        && (data.get('externalLink', null) == null || (data.externalLink is string && data.externalLink.size() <= 5000))
        && (data.get('daysOnMarket', null) == null || (data.daysOnMarket is number))
        && (data.get('colSpan', null) == null || (data.colSpan is number))
        && (data.get('rowSpan', null) == null || (data.rowSpan is number))
        && (data.get('hidden', null) == null || (data.hidden is bool))
        && (data.get('bannerText', null) == null || (data.bannerText is string && data.bannerText.size() <= 500))
        && (data.get('bannerColor', null) == null || (data.bannerColor is string && data.bannerColor.size() <= 100))
        && (data.get('bannerSize', null) == null || (data.bannerSize is string && data.bannerSize.size() <= 50))
        && (data.get('type', null) == null || (data.type is string && (data.type == 'item' || data.type == 'spacer')))
        && (data.get('panel', null) == null || (data.panel is string && (data.panel == 'main' || data.panel == 'side')))
        && (data.get('partnerUid', null) == null || (data.partnerUid is string && data.partnerUid.size() <= 128))
        && (data.get('partnerUids', null) == null || (data.partnerUids is list))
        && data.order is number;
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description', 'order', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && (data.get('price', null) == null || (data.price is string && data.price.size() <= 100))
        && (data.get('url', null) == null || (data.url is string && data.url.size() <= 1000))
        && data.order is number;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['propertyAddress', 'realtorName', 'email', 'serviceType', 'createdAt'])
        && data.propertyAddress is string && data.propertyAddress.size() <= 500
        && data.realtorName is string && data.realtorName.size() <= 200
        && data.email is string && data.email.size() <= 200;
    }

    function isValidSiteSettings(data) {
      return data.keys().hasAll(['brandName', 'updatedAt'])
        && data.brandName is string && data.brandName.size() <= 100
        && (data.get('logoText', null) == null || (data.logoText is string))
        && (data.get('heroTitlePart1', null) == null || (data.heroTitlePart1 is string))
        && (data.get('heroTitlePart2', null) == null || (data.heroTitlePart2 is string))
        && (data.get('heroTitleAccent', null) == null || (data.heroTitleAccent is string && data.heroTitleAccent.size() <= 100))
        && (data.get('tagline', null) == null || (data.tagline is string))
        && (data.get('logoLight', null) == null || (data.logoLight is string && data.logoLight.size() <= 2000))
        && (data.get('logoDark', null) == null || (data.logoDark is string && data.logoDark.size() <= 2000))
        && (data.get('heroImage', null) == null || (data.heroImage is string && data.heroImage.size() <= 2000))
        && (data.get('heroAlignment', null) == null || (data.heroAlignment is string))
        && (data.get('homeSectionsOrder', null) == null || (data.homeSectionsOrder is list))
        && (data.get('navigationItems', null) == null || (data.navigationItems is list))
        && (data.get('socialLinks', null) == null || (data.socialLinks is list))
        && (data.get('contactInfo', null) == null || (data.contactInfo is map))
        && (data.get('servicesTitle', null) == null || (data.servicesTitle is string))
        && (data.get('servicesSubtitle', null) == null || (data.servicesSubtitle is string))
        && (data.get('footerQuote', null) == null || (data.footerQuote is string))
        && (data.get('inquiryTitle', null) == null || (data.inquiryTitle is string))
        && (data.get('accentColor', null) == null || (data.accentColor is string))
        && (data.get('fontTitle', null) == null || (data.fontTitle is string))
        && (data.get('fontBody', null) == null || (data.fontBody is string))
        && (data.get('chatbotEnabled', null) == null || (data.chatbotEnabled is bool))
        && (data.get('chatbotPersona', null) == null || (data.chatbotPersona is string && data.chatbotPersona.size() <= 10000))
        && (data.get('chatbotPricing', null) == null || (data.chatbotPricing is map))
        && (data.get('layout', null) == null || (data.layout is map));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['prompt', 'createTime'])
        && data.prompt is string && data.prompt.size() <= 20000
        && (data.get('displayPrompt', null) == null || (data.displayPrompt is string && data.displayPrompt.size() <= 10000))
        && (data.get('response', null) == null || (data.response is string && data.response.size() <= 30000));
    }

    function isValidPage(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'showInNav', 'order', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200
        && data.slug is string && data.slug.size() <= 100
        && (data.get('description', null) == null || (data.description is string && data.description.size() <= 2000))
        && (data.get('layout', null) == null || (data.layout is map));
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'brokerage', 'quote', 'headshotUrl', 'order', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 200
        && data.brokerage is string && data.brokerage.size() <= 200
        && data.quote is string && data.quote.size() <= 2000
        && data.headshotUrl is string && data.headshotUrl.size() <= 2000
        && data.order is number;
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'role', 'addedAt'])
        && data.email is string && data.email.size() <= 200
        && data.role is string && (data.role == 'owner' || data.role == 'admin')
        && data.addedAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string && data.email.size() <= 200
        && (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 200))
        && (data.get('headshotUrl', null) == null || (data.headshotUrl is string && data.headshotUrl.size() <= 2000))
        && (data.get('logoUrl', null) == null || (data.logoUrl is string && data.logoUrl.size() <= 2000))
        && (data.get('instagram', null) == null || (data.instagram is string && data.instagram.size() <= 200))
        && (data.get('facebook', null) == null || (data.facebook is string && data.facebook.size() <= 200))
        && (data.get('linkedin', null) == null || (data.linkedin is string && data.linkedin.size() <= 200))
        && (data.get('bio', null) == null || (data.bio is string && data.bio.size() <= 5000))
        && (data.get('role', null) == null || (data.role is string && (data.role == 'client' || data.role == 'partner' || data.role == 'admin')))
        && (data.get('updatedAt', null) == null || true);
    }

    function isValidReferral(data) {
      return data.keys().hasAll(['referrerUid', 'referralName', 'status', 'createdAt'])
        && data.referrerUid is string && data.referrerUid.size() <= 128
        && data.referralName is string && data.referralName.size() <= 200
        && data.status is string && (data.status == 'Contacting...' || data.status == 'Pending' || data.status == 'Booked' || data.status == 'Completed')
        && (data.get('email', null) == null || (data.email is string && data.email.size() <= 200))
        && (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 50))
        && (data.get('notes', null) == null || (data.notes is string && data.notes.size() <= 5000))
        && (data.get('rewardEarned', null) == null || (data.rewardEarned is string && data.rewardEarned.size() <= 200))
        && (data.get('value', null) == null || (data.value is number))
        && (data.get('updatedAt', null) == null || true);
    }

    // 3. Collection Rules
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidAdmin(incoming()) && isValidId(adminId);
    }
    match /portfolio_items/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPortfolioItem(incoming()) && isValidId(itemId)
        && incoming().keys().hasAll(['title', 'category', 'img', 'order', 'createdAt', 'updatedAt'])
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isAdmin() 
        && isValidPortfolioItem(incoming())
        && (existing().get('createdAt', null) == null || incoming().createdAt == existing().createdAt)
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'img', 'description', 'gallery', 'order', 'url', 'mlsNumber', 'listPrice', 'propertyType', 'beds', 'baths', 'sqft', 'status', 'externalLink', 'daysOnMarket', 'colSpan', 'rowSpan', 'type', 'panel', 'hidden', 'bannerText', 'bannerColor', 'bannerSize', 'updatedAt', 'partnerUid', 'partnerUids'])
        );
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidService(incoming()) && isValidId(serviceId)
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isAdmin()
        && isValidService(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'url', 'order', 'updatedAt'])
        );
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(incoming()) && isValidId(inquiryId)
        && incoming().createdAt == request.time;
      allow read, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAdmin() && isValidTestimonial(incoming()) && isValidId(testimonialId)
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isAdmin()
        && isValidTestimonial(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'brokerage', 'quote', 'headshotUrl', 'order', 'updatedAt'])
        );
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSiteSettings(incoming())
        && incoming().updatedAt == request.time;
    }

    match /pages/{pageId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPage(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isAdmin() 
        && isValidPage(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'slug', 'content', 'showInNav', 'order', 'description', 'layout', 'updatedAt'])
        );
      allow delete: if isAdmin();
    }

    match /users/{userId}/chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidChat(incoming())
        && incoming().createTime == request.time;
      allow update: if isSignedIn() && request.auth.uid == userId && isValidChat(incoming())
        && incoming().createTime == existing().createTime
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['response'])
        );
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId 
        && isValidUser(incoming())
        && isValidId(userId)
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin())
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && (incoming().get('updatedAt', null) == null || incoming().updatedAt == request.time)
        && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'headshotUrl', 'logoUrl', 'instagram', 'facebook', 'linkedin', 'bio', 'updatedAt']))
        && (isAdmin() || incoming().get('role', existing().get('role', 'client')) == existing().get('role', 'client'));
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.referrerUid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == incoming().referrerUid
        && isValidReferral(incoming())
        && isValidId(referralId)
        && incoming().createdAt == request.time;
      allow update: if isAdmin() 
        && isValidReferral(incoming())
        && incoming().createdAt == existing().createdAt
        && (incoming().get('updatedAt', null) == null || incoming().updatedAt == request.time)
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'rewardEarned', 'value', 'updatedAt'])
        );
    }
  }
}
