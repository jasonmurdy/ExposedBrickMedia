# Fotello CRM API Key for advanced scheduling pipelines and syncing
FOTELLO_API_KEY=api-074832e3d4901ef4d1ec4e8dc98072bcae703dca2b1155dc

# Set to 'true' to attempt live connection calls to Fotello API instead of local high-fidelity simulation
